{
  "name": "@nexus-form/worker",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rollup -c rollup.config.mjs",
    "start": "node dist/index.mjs",
    "type-check": "tsgo --noEmit",
