  "dependencies": {
    "@nexus-form/database": "workspace:*",
    "@nexus-form/integrations": "workspace:*",
    "@nexus-form/shared": "workspace:*",
    "@nexus-form/validation-provider-discord": "workspace:*",
    "@nexus-form/validation-provider-github": "workspace:*",
    "@nexus-form/validation-provider-twitter": "workspace:*",
    "@octokit/auth-app": "^7.2.2",
    "@octokit/rest": "^21.1.1",
    "@sentry/node": "^10.40.0",
    "axios": "^1.15.2",
    "bullmq": "^5.69.2",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.9.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.32.6",
    "speakeasy": "^2.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
