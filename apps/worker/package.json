    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.12.4",
    "@types/speakeasy": "^2.0.10",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "glob": "^11.0.0",
    "mysql2": "^3.14.4",
    "rollup": "^4.60.4",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
