{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["vitest/globals"],
    "paths": {
      "@nexus-form/shared": ["../../packages/shared/src/index.ts"],
      "@nexus-form/shared/*": ["../../packages/shared/src/*"],
      "@/*": ["./src/*"],
      "@content/*": ["../../content/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
