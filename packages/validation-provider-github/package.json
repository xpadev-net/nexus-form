{
  "name": "@nexus-form/validation-provider-github",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "import": "./dist/plugin.mjs"
    }
  },
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsdown",
    "type-check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@nexus-form/integrations": "workspace:*",
    "@octokit/auth-app": "^7.2.2",
    "@octokit/rest": "^21.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/node": "^24.10.13",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
