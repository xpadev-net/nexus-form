{
  "name": "@nexus-form/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./validation": {
      "types": "./src/validation/shared.ts",
      "import": "./dist/validation/shared.js",
      "default": "./dist/validation/shared.js"
    },
    "./plate-content": {
      "types": "./src/plate-content-utils.ts",
      "import": "./dist/plate-content-utils.js",
      "default": "./dist/plate-content-utils.js"
    },
    "./forms/form-block": {
      "types": "./src/forms/form-block.ts",
      "import": "./dist/forms/form-block.js",
      "default": "./dist/forms/form-block.js"
    },
    "./crypto/field-encryption": {
      "types": "./src/crypto/field-encryption.ts",
      "import": "./dist/crypto/field-encryption.js",
      "default": "./dist/crypto/field-encryption.js"
    },
    "./branding": {
      "types": "./src/branding.ts",
      "import": "./dist/branding.js",
      "default": "./dist/branding.js"
    },
    "./constants/status": {
      "types": "./src/constants/status.ts",
      "import": "./dist/constants/status.js",
      "default": "./dist/constants/status.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "type-check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.15",
    "@types/node": "^24.10.13",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
