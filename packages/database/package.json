{
  "name": "@nexus-form/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./src/schema.ts",
      "import": "./dist/schema.js"
    },
    "./migrate": {
      "types": "./src/migrate.ts",
      "import": "./dist/migrate.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsgo --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe"
  },
  "dependencies": {
    "@nexus-form/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.23.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^24.12.4",
    "@typescript/native-preview": "7.0.0-dev.20260616.1",
    "drizzle-kit": "^0.31.10",
    "tsdown": "^0.22.1",
    "typescript": "^5.9.3"
  }
}
