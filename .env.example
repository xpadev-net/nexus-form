# ===========================================
# フォームアプリケーション 環境変数テンプレート
# ===========================================
# このファイルを .env.local にコピーして使用してください

# ===========================================
# アプリケーション基本設定
# ===========================================
# Better Auth シークレットキー
AUTH_SECRET=your-auth-secret-key-change-this-in-production

# Hono API サーバーの信頼するオリジン（カンマ区切り）
TRUSTED_ORIGINS=http://localhost:3000

# ===========================================
# Vite フロントエンド設定 (VITE_ プレフィックス)
# ===========================================
# API サーバーの URL
VITE_API_URL=http://localhost:3001

# 公開URL (本番環境では https://yourdomain.com のように設定)
# Better Auth の callbackURL の基準オリジン（フロントエンド側）
VITE_BASE_URL=http://localhost:3000

# ===========================================
# API サーバー設定
# ===========================================
# API サーバーの公開URL（Google OAuth リダイレクトURI の基準オリジン）
# 未設定時は Google OAuth 連携が無効化されます
API_BASE_URL=http://localhost:3001

# ===========================================
# データベース設定 (MySQL)
# ===========================================
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
MYSQL_USER=nexus_form_app
MYSQL_PASSWORD=replace-with-a-long-random-app-password
MYSQL_DATABASE=nexus_form
# IMPORTANT: Copy this file to both .env (Docker Compose) and .env.local (app).
# The password in DATABASE_URL must be identical to MYSQL_PASSWORD above.
# When you rotate MYSQL_PASSWORD, update DATABASE_URL in .env.local at the same time.
# Docker Compose reads MYSQL_PASSWORD from .env; the app reads DATABASE_URL from .env.local.
# If they diverge, the app cannot connect to MySQL.
DATABASE_URL="mysql://nexus_form_app:replace-with-a-long-random-app-password@localhost:3306/nexus_form"

# ===========================================
# Redis 設定 (キャッシュ用)
# ===========================================
REDIS_PASSWORD=replace-with-a-long-random-redis-password
# IMPORTANT: Copy this file to both .env (Docker Compose) and .env.local (app).
# The password in REDIS_URL must be identical to REDIS_PASSWORD above.
# When you rotate REDIS_PASSWORD, update REDIS_URL in .env.local at the same time.
# Docker Compose reads REDIS_PASSWORD from .env; the app reads REDIS_URL from .env.local.
# If they diverge, the app cannot connect to Redis.
REDIS_URL=redis://:replace-with-a-long-random-redis-password@localhost:6379

# ===========================================
# Discord OAuth 設定
# ===========================================
# Discord Developer Portal でアプリケーションを作成し、以下を設定してください
# https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ===========================================
# Google OAuth 設定
# ===========================================
# Google Cloud ConsoleでOAuthクライアントを作成
# 認可リダイレクトURI: http://localhost:3001/api/integrations/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# Google OAuth トークン暗号化専用キー（AUTH_SECRETとは分離して必須）
# 既存環境で未設定だった場合、保存済みトークンは旧AUTH_SECRET由来の鍵で暗号化されているため移行前に同値を設定してください
GOOGLE_OAUTH_ENC_KEY=your-long-random-key
# フラグ: Google Sheets連携とOAuth
GOOGLE_SHEETS_INTEGRATION_ENABLED=true
GOOGLE_SHEETS_OAUTH_ENABLED=true

# ===========================================
# 招待コード設定
# ===========================================
# 新規サインアップ時に必要な招待コード
SIGNUP_INVITATION_CODE=your-invitation-code-here

# ===========================================
# S3互換ストレージ設定 (MinIO)
# ===========================================
# 開発環境ではMinIOを使用
# IMPORTANT: Local Compose reads MINIO_ROOT_USER and MINIO_ROOT_PASSWORD.
# The app reads S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY from .env.local.
# Keep the S3 credential pair identical to the MinIO root pair whenever creating or rotating local MinIO credentials.
MINIO_ROOT_USER=replace-with-a-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-root-password
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=replace-with-a-minio-root-user
S3_SECRET_ACCESS_KEY=replace-with-a-long-random-minio-root-password
S3_BUCKET_TMP=nexus-form-tmp
S3_BUCKET_PROD=nexus-form-prod

# 本番環境では以下の環境変数を使用:
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_REGION=ap-northeast-1
# S3_BUCKET_TMP=nexus-form-tmp
# S3_BUCKET_PROD=nexus-form-prod

# ===========================================
# 外部サービス設定
# ===========================================
# Discord Bot Token (権限チェック用)
DISCORD_BOT_TOKEN=your-discord-bot-token

# --- GitHub App 認証 ---
# 用途: GitHub App での API 認可。App 設定画面で App ID と鍵を取得。
# 参考: https://docs.github.com/apps
# 注意: GITHUB_PRIVATE_KEY は複数行。`.env` では \n に置換する運用例あり。
# 例) GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Twitter API v2 認証 ---
# 用途: アプリケーション専用ベアラートークン。
# 参考: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ===========================================
# hCaptcha 設定
# ===========================================
# hCaptcha サイトキー (公開可能、フロントエンドで使用)
# https://dashboard.hcaptcha.com/ で取得
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# 開発環境でフォーム送信のセキュリティ機能をまとめて無効化する場合のみ true に設定
# hCaptcha、テレメトリIP/トークン、フィンガープリント必須チェックが対象です
# production ではこの値は無視されます
VITE_FORM_SECURITY_DEV_BYPASS=false
FORM_SECURITY_DEV_BYPASS=false

# Deprecated: hCaptcha のみを無効化する旧フラグです。新規では上記の統合フラグを使用してください
VITE_DISABLE_HCAPTCHA=false
DISABLE_HCAPTCHA=false

# hCaptcha シークレットキー (サーバー側でのみ使用、秘密情報)
# https://dashboard.hcaptcha.com/ で取得
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# ===========================================
# セキュリティ設定
# ===========================================
# CSRF保護用の秘密鍵
CSRF_SECRET=your-csrf-secret-key-change-this-in-production

# セッションIPハッシュ化用のソルト（オプション、未設定時はAUTH_SECRETから導出）
SESSION_IP_SALT=your-session-ip-salt-change-this-in-production

# ===========================================
# セッション管理設定
# ===========================================
# セッションエイリアス用のソルト（必須）
SESSION_ALIAS_SALT=your-session-alias-salt-change-this-in-production

# ===========================================
# 監視・ログ設定
# ===========================================
# Sentry DSN (エラートラッキング用)
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=production

# ===========================================
# 開発環境専用設定
# ===========================================
# デバッグモード
NODE_ENV=development
DEBUG=true

# ログレベル
LOG_LEVEL=debug

# ===========================================
# プライバシー・セキュリティ設定
# ===========================================
# フィンガープリント収集の有効/無効
ENABLE_FINGERPRINT_COLLECTION=true

# データ保持期間 (日数)
DATA_RETENTION_DAYS=365

# ===========================================
# 外部サービス検証設定
# ===========================================
# 各サービスの検証結果キャッシュ時間 (秒)
EXTERNAL_SERVICE_CACHE_TTL=3600

# ===========================================
# 画像処理設定
# ===========================================
# 最大ファイルサイズ (MB)
MAX_FILE_SIZE_MB=10

# 許可される画像形式
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# ===========================================
# スケジュール機能設定
# ===========================================
# タイムゾーン設定
DEFAULT_TIMEZONE=Asia/Tokyo

# ===========================================
# Telemetry設定（オプション）
# ===========================================
# IPv4 telemetryホスト
VITE_TELEMETRY_V4_HOST=ipv4.example.com

# IPv6 telemetryホスト
VITE_TELEMETRY_V6_HOST=ipv6.example.com

# Telemetryトークンの有効期限（秒）
TELEMETRY_TOKEN_TTL_SEC=600

# IPアドレスハッシュ化用のソルト
TELEMETRY_IP_SALT=your-telemetry-ip-salt-change-this-in-production
