# ===========================================
# フォームアプリケーション 環境変数テンプレート
# ===========================================
# このファイルを .env.local にコピーして使用してください

# ===========================================
# アプリケーション基本設定
# ===========================================
# Better Auth シークレットキー
AUTH_SECRET=your-auth-secret-key-change-this-in-production

# Hono API サーバーの信頼するオリジン（カンマ区切り）
TRUSTED_ORIGINS=http://localhost:3000

# ===========================================
# Vite フロントエンド設定 (VITE_ プレフィックス)
# ===========================================
# API サーバーの URL
VITE_API_URL=http://localhost:3001

# 公開URL (本番環境では https://yourdomain.com のように設定)
# Better Auth の callbackURL の基準オリジン（フロントエンド側）
VITE_BASE_URL=http://localhost:3000

# ===========================================
# API サーバー設定
# ===========================================
# API サーバーの公開URL（Google OAuth リダイレクトURI の基準オリジン）
# 未設定時は Google OAuth 連携が無効化されます
API_BASE_URL=http://localhost:3001

# ===========================================
# データベース設定 (MySQL)
# ===========================================
MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
MYSQL_USER=nexus_form_app
MYSQL_PASSWORD=replace-with-a-long-random-app-password
MYSQL_DATABASE=nexus_form
# IMPORTANT: Copy this file to both .env (Docker Compose) and .env.local (app).
# The password in DATABASE_URL must be identical to MYSQL_PASSWORD above.
# When you rotate MYSQL_PASSWORD, update DATABASE_URL in .env.local at the same time.
# Docker Compose reads MYSQL_PASSWORD from .env; the app reads DATABASE_URL from .env.local.
# If they diverge, the app cannot connect to MySQL.
DATABASE_URL="mysql://nexus_form_app:replace-with-a-long-random-app-password@localhost:3306/nexus_form"

# ===========================================
# Redis 設定 (キャッシュ用)
# ===========================================
REDIS_PASSWORD=replace-with-a-long-random-redis-password
# IMPORTANT: Copy this file to both .env (Docker Compose) and .env.local (app).
# The password in REDIS_URL must be identical to REDIS_PASSWORD above.
# When you rotate REDIS_PASSWORD, update REDIS_URL in .env.local at the same time.
# Docker Compose reads REDIS_PASSWORD from .env; the app reads REDIS_URL from .env.local.
# If they diverge, the app cannot connect to Redis.
REDIS_URL=redis://:replace-with-a-long-random-redis-password@localhost:6379

# ===========================================
# Discord OAuth 設定
# ===========================================
# Discord Developer Portal でアプリケーションを作成し、以下を設定してください
# https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# ===========================================
# Google OAuth 設定
# ===========================================
# Google Cloud ConsoleでOAuthクライアントを作成
# 認可リダイレクトURI: http://localhost:3001/api/integrations/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# Google OAuth トークン暗号化専用キー（AUTH_SECRETとは分離して必須）
# 既存環境で未設定だった場合、保存済みトークンは旧AUTH_SECRET由来の鍵で暗号化されているため移行前に同値を設定してください
GOOGLE_OAUTH_ENC_KEY=your-long-random-key
# フラグ: Google Sheets連携とOAuth
GOOGLE_SHEETS_INTEGRATION_ENABLED=true
GOOGLE_SHEETS_OAUTH_ENABLED=true

# ===========================================
# 招待コード設定
# ===========================================
# 新規サインアップ時に必要な招待コード
SIGNUP_INVITATION_CODE=your-invitation-code-here

# ===========================================
# S3互換ストレージ設定 (MinIO)
# ===========================================
# 開発環境ではMinIOを使用
# IMPORTANT: Local Compose reads MINIO_ROOT_USER and MINIO_ROOT_PASSWORD.
# The app reads S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY from .env.local.
# Keep the S3 credential pair identical to the MinIO root pair whenever creating or rotating local MinIO credentials.
MINIO_ROOT_USER=replace-with-a-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-a-long-random-minio-root-password
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=replace-with-a-minio-root-user
S3_SECRET_ACCESS_KEY=replace-with-a-long-random-minio-root-password
S3_BUCKET_TMP=nexus-form-tmp
S3_BUCKET_PROD=nexus-form-prod

# 本番環境では以下の環境変数を使用:
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_REGION=ap-northeast-1
# S3_BUCKET_TMP=nexus-form-tmp
# S3_BUCKET_PROD=nexus-form-prod

# ===========================================
# 外部サービス設定
# ===========================================
# Discord Bot Token (権限チェック用)
DISCORD_BOT_TOKEN=your-discord-bot-token

# --- GitHub App 認証 ---
# 用途: GitHub App での API 認可。App 設定画面で App ID と鍵を取得。
# 参考: https://docs.github.com/apps
# 注意: GITHUB_PRIVATE_KEY は複数行。`.env` では \n に置換する運用例あり。
# 例) GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Twitter API v2 認証 ---
# 用途: アプリケーション専用ベアラートークン。
# 参考: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ===========================================
# hCaptcha 設定
# ===========================================
# hCaptcha サイトキー (公開可能、フロントエンドで使用)
# https://dashboard.hcaptcha.com/ で取得
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# 開発環境でフォーム送信のセキュリティ機能をまとめて無効化する場合のみ true に設定
# hCaptcha、テレメトリIP/トークン、フィンガープリント必須チェックが対象です
# production ではこの値は無視されます
VITE_FORM_SECURITY_DEV_BYPASS=false
FORM_SECURITY_DEV_BYPASS=false

# Deprecated: hCaptcha のみを無効化する旧フラグです。新規では上記の統合フラグを使用してください
VITE_DISABLE_HCAPTCHA=false
DISABLE_HCAPTCHA=false

# hCaptcha シークレットキー (サーバー側でのみ使用、秘密情報)
# https://dashboard.hcaptcha.com/ で取得
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key

# ===========================================
# セキュリティ設定
# ===========================================
# CSRF保護用の秘密鍵
CSRF_SECRET=your-csrf-secret-key-change-this-in-production

# セッションIPハッシュ化用のソルト（オプション、未設定時はAUTH_SECRETから導出）
SESSION_IP_SALT=your-session-ip-salt-change-this-in-production

# ===========================================
# セッション管理設定
# ===========================================
# セッションエイリアス用のソルト（必須）
SESSION_ALIAS_SALT=your-session-alias-salt-change-this-in-production

# ===========================================
# 監視・ログ設定
# ===========================================
# Sentry DSN (エラートラッキング用)
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ENVIRONMENT=production

# ===========================================
# 開発環境専用設定
# ===========================================
# デバッグモード
NODE_ENV=development
DEBUG=true

# ログレベル
LOG_LEVEL=debug

# ===========================================
# プライバシー・セキュリティ設定
# ===========================================
# フィンガープリント収集の有効/無効
ENABLE_FINGERPRINT_COLLECTION=true

# データ保持期間 (日数)
DATA_RETENTION_DAYS=365

# ===========================================
# 外部サービス検証設定
# ===========================================
# 各サービスの検証結果キャッシュ時間 (秒)
EXTERNAL_SERVICE_CACHE_TTL=3600

# ===========================================
# 画像処理設定
# ===========================================
# 最大ファイルサイズ (MB)。アップロード検証と画像処理の共通上限です。
MAX_FILE_SIZE_MB=10

# 許可される画像形式（アップロード検証と画像処理入力の共通 allowlist）
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif,image/svg+xml

# ===========================================
# スケジュール機能設定
# ===========================================
# タイムゾーン設定
DEFAULT_TIMEZONE=Asia/Tokyo

# ===========================================
# Telemetry設定（オプション）
# ===========================================
# 共通 telemetryホスト（環境別の上書きが不要な場合）。bare host は https:// として扱われ、URL path は endpoint の base path として保持されます。
VITE_TELEMETRY_HOST=telemetry.example.com

# IPv4 telemetryホスト（公開フォーム送信時の v4 token 取得で VITE_TELEMETRY_HOST より優先）
VITE_TELEMETRY_V4_HOST=ipv4.example.com

# IPv6 telemetryホスト（v4 host 未設定時の公開フォーム送信用 v6 token 取得で使用）
VITE_TELEMETRY_V6_HOST=ipv6.example.com

# Telemetryトークンの有効期限（秒）
TELEMETRY_TOKEN_TTL_SEC=600

# IPアドレスハッシュ化用のソルト
TELEMETRY_IP_SALT=your-telemetry-ip-salt-change-this-in-production

# ===========================================
# API サーバー詳細設定
# ===========================================
# API サーバーのポート番号（デフォルト: 3001）
# PORT=3001

# プロキシ信頼段数（X-Forwarded-For の末尾から N 番目をクライアント IP として採用）
# プロキシなし構成では 0（デフォルト）、nginx 等 1 段なら 1
# TRUSTED_PROXY_COUNT=1

# API サーバーのグレースフルシャットダウンタイムアウト（ミリ秒、デフォルト: 10000）
# API_SHUTDOWN_TIMEOUT_MS=10000

# hCaptcha 検証時に期待するホスト名（カンマ区切り、本番環境で必須）
# HCAPTCHA_EXPECTED_HOSTNAMES=yourdomain.com

# 招待リンクのベース URL（メール通知等で使用）
# 未設定時は TRUSTED_ORIGINS の先頭を使用
# INVITE_BASE_URL=https://yourdomain.com

# デプロイ時の Git ハッシュ（CI/CD で自動注入、手動設定不要）
# GIT_HASH=

# ===========================================
# ブランド設定 (BRAND_* / VITE_BRAND_*)
# ===========================================
# ランタイム値 (Docker env / k8s ConfigMap) がビルド時値より優先されます
# 未設定時はデフォルト値 (nexus-form) が使用されます

# --- サーバーサイド (BRAND_*) ---
# BRAND_APP_NAME=nexus-form
# BRAND_PRIMARY_COLOR=#3b82f6
# BRAND_SECONDARY_COLOR=#6b7280
# BRAND_ACCENT_COLOR=#f59e0b
# BRAND_TERMS_URL=
# BRAND_PRIVACY_URL=
# BRAND_COPYRIGHT=
# BRAND_HOMEPAGE_URL=
# BRAND_COOKIE_PREFIX=
# BRAND_USER_AGENT=
# BRAND_MONITOR_USER_AGENT=

# --- フロントエンド (VITE_BRAND_*) ---
# VITE_BRAND_APP_NAME=nexus-form
# VITE_BRAND_PRIMARY_COLOR=#3b82f6
# VITE_BRAND_SECONDARY_COLOR=#6b7280
# VITE_BRAND_ACCENT_COLOR=#f59e0b
# VITE_BRAND_TERMS_URL=
# VITE_BRAND_PRIVACY_URL=
# VITE_BRAND_COPYRIGHT=
# VITE_BRAND_HOMEPAGE_URL=

# ===========================================
# Worker 設定 (apps/worker)
# ===========================================
# キュー名のカンマ区切りリスト（デフォルト: 全キュー有効）
# WORKER_QUEUES=discord-validation,github-validation,twitter-validation,google-sheets-sync

# Worker の最大同時実行ジョブ数（デフォルト: 5）
# WORKER_CONCURRENCY=5

# キュー別の同時実行数（キュー名でオーバーライド）
# WORKER_CONCURRENCY_DISCORD_VALIDATION=3
# WORKER_CONCURRENCY_GITHUB_VALIDATION=3
# WORKER_CONCURRENCY_TWITTER_VALIDATION=3
# WORKER_CONCURRENCY_GOOGLE_SHEETS_SYNC=3

# Worker のグレースフルシャットダウンタイムアウト（ミリ秒、デフォルト: 30000）
# WORKER_SHUTDOWN_TIMEOUT_MS=30000

# ===========================================
# キュー監視設定
# ===========================================
# キューメトリクスの収集間隔（ミリ秒、デフォルト: 60000）
# QUEUE_METRICS_INTERVAL=60000

# キューメトリクスのサンプルサイズ（デフォルト: 500）
# QUEUE_METRICS_SAMPLE_SIZE=500

# サービスモニタリングの実行間隔（ミリ秒、デフォルト: 300000 = 5分）
# SERVICE_MONITORING_INTERVAL=300000

# ===========================================
# Redis 詳細設定（デフォルトは REDIS_URL から自動解決）
# ===========================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_TLS=false

# Redis Sentinel 構成（REDIS_URL の代わりに使用可能）
# REDIS_SENTINELS=sentinel1:26379,sentinel2:26379
# REDIS_SENTINEL_MASTER_NAME=mymaster
# REDIS_SENTINEL_PASSWORD=

# ===========================================
# 画像処理詳細設定
# ===========================================
# ファイルサイズと許可 MIME type は上記 MAX_FILE_SIZE_MB / ALLOWED_IMAGE_TYPES を使用します。
# Deprecated: MAX_IMAGE_SIZE は MAX_FILE_SIZE_MB に置き換えられました。

# 最大画像寸法（ピクセル、デフォルト: 4096）
# MAX_IMAGE_DIMENSION=4096

# 最大画像ピクセル数（width * height、デフォルト: 268402689）
# MAX_IMAGE_PIXELS=268402689

# 画像処理の同時実行制限（デフォルト: 3）
# IMAGE_CONCURRENT_LIMIT=3

# 画像処理のレート制限
# IMAGE_RATE_LIMIT_WINDOW=60000
# IMAGE_RATE_LIMIT_GLOBAL=3
# IMAGE_RATE_LIMIT_PER_USER_WINDOW=60000
# IMAGE_RATE_LIMIT_PER_USER=5
# IMAGE_RATE_LIMIT_PER_IP_WINDOW=60000
# IMAGE_RATE_LIMIT_PER_IP=10

# ===========================================
# バリデーションプラグイン設定
# ===========================================
# 外部バリデーションプラグインの配置ディレクトリ
# デフォルト: /app/plugins/validation (Docker), ./plugins (開発環境)
# VALIDATION_PLUGINS_DIR=./plugins

# プラグイン読み込み失敗時の起動ポリシー（デフォルト: true）
# true: 失敗時に起動を中止（本番推奨）
# false: 警告ログのみで起動継続
# VALIDATION_PLUGINS_FAIL_FAST=true

# ===========================================
# Validation Outbox 設定
# ===========================================
# 未処理ジョブのスイープ間隔（ミリ秒、デフォルト: 60000）
# VALIDATION_OUTBOX_SWEEP_INTERVAL_MS=60000

# 1回のスイープで処理する最大ジョブ数（デフォルト: 100）
# VALIDATION_OUTBOX_SWEEP_BATCH_SIZE=100

# ジョブが滞留と判定される経過時間（ミリ秒、デフォルト: 30000 = 30秒）
# VALIDATION_OUTBOX_SWEEP_STALE_MS=30000

# ===========================================
# Discord バリデーション詳細設定
# ===========================================
# Discord API のタイムアウト（ミリ秒、デフォルト: 10000）
# DISCORD_API_TIMEOUT_MS=10000

# バリデーション結果のキャッシュ時間（ミリ秒、デフォルト: 300000 = 5分）
# DISCORD_CACHE_TIMEOUT=300000

# リトライ回数（デフォルト: 3）
# DISCORD_RETRY_ATTEMPTS=3

# リトライ遅延（ミリ秒、デフォルト: 1000）
# DISCORD_RETRY_DELAY=1000

# Bot の Discord Intents（カンマ区切り、デフォルト: Guilds,GuildMembers,GuildPresences）
# DISCORD_INTENTS=Guilds,GuildMembers,GuildPresences

# Bot 追加時の Discord OAuth リダイレクト URI
# DISCORD_REDIRECT_URI=

# Bot の OAuth スコープ（カンマ区切り、デフォルト: identify,guilds,guilds.members.read）
# DISCORD_SCOPES=identify,guilds,guilds.members.read

# ===========================================
# GitHub バリデーション詳細設定
# ===========================================
# GitHub API のタイムアウト（ミリ秒、デフォルト: 15000）
# GITHUB_API_TIMEOUT_MS=15000

# バリデーション結果のキャッシュ有効期限（ミリ秒、デフォルト: 3600 = 3.6秒）
# GITHUB_CACHE_EXPIRY=3600

# GitHub App のインストール ID
# GITHUB_INSTALLATION_ID=

# ===========================================
# Twitter バリデーション詳細設定
# ===========================================
# Twitter API のタイムアウト（ミリ秒、デフォルト: 30000）
# TWITTER_TIMEOUT=30000

# Twitter API のベース URL（デフォルト: https://api.twitter.com）
# TWITTER_BASE_URL=https://api.twitter.com

# Twitter API バージョン（デフォルト: 2）
# TWITTER_API_VERSION=2

# ===========================================
# Google Sheets 同期設定
# ===========================================
# Google Sheets API のタイムアウト（ミリ秒、デフォルト: 30000）
# GOOGLE_SHEETS_API_TIMEOUT_MS=30000



# ===========================================
# SSE（Server-Sent Events）設定
# ===========================================
# プロセスあたりの最大 SSE 接続数（デフォルト: 200）
# SSE_MAX_CONNECTIONS=200

# ユーザーあたりの最大 SSE 接続数（デフォルト: 20）
# SSE_MAX_CONNECTIONS_PER_USER=20

# フォームあたりの最大 SSE 接続数（デフォルト: 50）
# SSE_MAX_CONNECTIONS_PER_FORM=50

# クライアントあたりの保留メッセージ最大数（デフォルト: 100）
# SSE_MAX_PENDING_MESSAGES_PER_CLIENT=100
