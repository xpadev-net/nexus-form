{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {},
    "lint:fix": {
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "dependsOn": ["^build"],
      "cache": true,
      "env": ["DATABASE_URL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/schema.ts",
        "src/auth-schema.ts",
        "drizzle.config.ts"
      ],
      "outputs": ["drizzle/**"]
    },
    "db:migrate": {
      "dependsOn": ["^build"],
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "clean": {
      "cache": false
    }
  }
}
